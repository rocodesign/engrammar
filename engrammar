#!/bin/bash
# Engrammar CLI wrapper

ENGRAMMAR_HOME="${ENGRAMMAR_HOME:-$HOME/.engrammar}"
CLI="$ENGRAMMAR_HOME/cli.py"

# OS-aware venv path
if [ -f "$ENGRAMMAR_HOME/venv/bin/python" ]; then
    PYTHON="$ENGRAMMAR_HOME/venv/bin/python"
elif [ -f "$ENGRAMMAR_HOME/venv/Scripts/python.exe" ]; then
    PYTHON="$ENGRAMMAR_HOME/venv/Scripts/python.exe"
elif [ -f "$ENGRAMMAR_HOME/venv/Scripts/python" ]; then
    PYTHON="$ENGRAMMAR_HOME/venv/Scripts/python"
else
    echo "Error: Engrammar not installed. Run the installer:"
    echo "  curl -fsSL https://raw.githubusercontent.com/rocodesign/engrammar/main/scripts/install.sh | bash"
    exit 1
fi

exec "$PYTHON" "$CLI" "$@"
